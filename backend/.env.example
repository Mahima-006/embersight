# EmberSight - Environment Variables
# -----------------------------------
# Copy this file to '.env' and fill in the values below.

# 1. NASA FIRMS API Key (Required for Live Wildfire Data)
# Get your free MAP_KEY here: https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=YOUR_FIRMS_MAP_KEY

# 2. OpenWeatherMap API Key (Required for Live Weather & Forecasts)
# Get your free API key here: https://openweathermap.org/api
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
